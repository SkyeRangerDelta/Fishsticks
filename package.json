{
  "name": "fishsticks",
  "version": "1.22.1",
  "description": "The official CCG Discord bot",
  "main": "fishsticks.js",
  "scripts": {
    "start": "node fishsticks.js",
    "test": "node fishsticks.js -test",
    "dev": "nodemon fishsticks.js -test",
    "build": "tsc",
    "build-run": "npm run build && npm run start",
    "docker-build": "docker build -t fishsticks .",
    "docker-run": "docker run -d fishsticks",
    "docker-stop": "docker stop $(docker ps -q --filter ancestor=fishsticks)",
    "docker-build-run": "npm run docker-build && npm run docker-run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SkyeRangerDelta/Fishsticks.git"
  },
  "author": "SkyeRangerDelta",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/SkyeRangerDelta/Fishsticks/issues"
  },
  "homepage": "https://github.com/SkyeRangerDelta/Fishsticks#readme",
  "dependencies": {
    "@discordjs/builders": "^1.14.1",
    "@discordjs/rest": "^2.6.0",
    "@napi-rs/canvas": "^1.0.0",
    "axios": "^1.16.0",
    "discord-api-types": "^0.38.47",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2",
    "mongodb": "^7.2.0",
    "openai": "^6.37.0",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24"
  }
}
